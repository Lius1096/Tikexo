# ── Dépendances ──────────────────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Variables d'environnement (JAMAIS commitées) ──────────────────────────────
# Attrape TOUT fichier .env et ses variantes dans tout sous-dossier
**/.env
**/.env.local
**/.env.*.local
**/.env.production
**/.env.staging
**/.env.test
# Sécurité explicite sur les dossiers clés
backend/.env
web/.env
mobile/.env
# Les .env.example sont des templates autorisés — valeurs fictives uniquement
!**/.env.example
!.env.example

# ── Build / dist ──────────────────────────────────────────────────────────────
dist/
build/
out/
.next/
.nuxt/
.output/
web/dist/
mobile/dist/

# ── Prisma ────────────────────────────────────────────────────────────────────
# Le client généré est reconstruit via `prisma generate` — inutile de le versionner
backend/node_modules/.prisma/
backend/src/generated/

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Tests / coverage ─────────────────────────────────────────────────────────
coverage/
.nyc_output/
web/e2e/test-results/
web/playwright-report/

# ── OS ───────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Éditeurs ─────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── Docker ───────────────────────────────────────────────────────────────────
# Les volumes locaux ne doivent pas être commités
tikexo_pgdata_dev/

# ── Traefik ──────────────────────────────────────────────────────────────────
# Certificat ACME généré automatiquement — ne pas commiter
traefik/acme.json

