# ─── Base de données ─────────────────────────────────────────────────────────
DATABASE_URL="postgresql://tikexo:password@postgres:5432/tikexo_prod"
DATABASE_TEST_URL="postgresql://tikexo:password@localhost:5432/tikexo_test"

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Paiements FedaPay ────────────────────────────────────────────────────────
FEDAPAY_SECRET_KEY=
FEDAPAY_PUBLIC_KEY=
FEDAPAY_ENV="sandbox"
FEDAPAY_WEBHOOK_SECRET=

# ─── Stockage Cloudinary ──────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Firebase (push mobile) ───────────────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ─── Serveur ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV="development"

# ─── Règles métier TIKEXO ─────────────────────────────────────────────────────
TIKEXO_COMMISSION_DEFAULT=2.00
TIKEXO_COMMISSION_MENSUEL=1.50
TIKEXO_PAYOUT_SEUIL_MINIMUM=1000
TIKEXO_PAYOUT_CYCLE_HEURES=72
TIKEXO_PLAFOND_JOURNALIER_DEFAULT=10000
TIKEXO_PLAFOND_SIMPLIFIE_MENSUEL=500000

# ─── Email SMTP ───────────────────────────────────────────────────────────────
# Option A — Gmail (temporaire, en attente du SMTP tikexo.bj)
#   1. Activer la validation en 2 étapes sur le compte Gmail
#   2. Générer un "Mot de passe d'application" : myaccount.google.com → Sécurité → Mots de passe des applications
#   3. Renseigner ci-dessous :
EMAIL=votre.compte@gmail.com          # Adresse Gmail expéditrice
EMAIL_PASSWORD=                        # Mot de passe d'application Gmail (16 chars, pas le vrai mdp)
MAIL_RECEIVER=                         # Email de réponse / destinataire des alertes internes

# Option B — Brevo / SMTP custom (production)
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=noreply@tikexo.bj
# SMTP_PASS=                           # Clé SMTP Brevo

# ─── Carte TIKEXO ─────────────────────────────────────────────────────────────
CARTE_PREFIXE=4782                # Préfixe BIN TIKEXO (4 chiffres)
CARTE_QR_SECRET_KEY=              # Clé HMAC-SHA256 QR codes (≥32 chars)
CARTE_NFC_SECRET_KEY=             # Clé HMAC-SHA256 tokens NFC (≥32 chars)
CARTE_CVV_SECRET_KEY=             # Clé HMAC-SHA256 CVV dynamique (≥32 chars)
CARTE_NFC_MONTANT_MAX=5000        # Montant max NFC sans confirmation biométrique (XOF)

# ─── SMS Africa's Talking ─────────────────────────────────────────────────────
# Couverture : MTN Bénin + Moov Africa — ~0,04 $/SMS
# Clé API : account.africastalking.com → Settings → API Key
SMS_API_KEY=
SMS_USERNAME=sandbox              # Remplacer par votre username AT en production

# ─── URLs ─────────────────────────────────────────────────────────────────────
FRONTEND_URL="https://tikexo.bj"
REDIS_URL=redis://redis:6379          # Docker : redis://redis:6379 | Local : redis://localhost:6379

# ─── Monitoring Sentry ────────────────────────────────────────────────────────
# DSN : sentry.io → Settings → Projects → Client Keys
# Gratuit jusqu'à 5 000 erreurs/mois
SENTRY_DSN=

# ─── Stockage objet S3 (MinIO dev / Cloudflare R2 prod) ──────────────────────
# Dev (MinIO Docker) : endpoint = http://minio:9000
# Prod (Cloudflare R2) : endpoint = https://<ACCOUNT_ID>.r2.cloudflarestorage.com
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=tikexo
S3_SECRET_KEY=tikexo_dev_secret
S3_BUCKET=tikexo-documents
S3_REGION=auto                        # "auto" pour R2, "us-east-1" pour MinIO
S3_PUBLIC_URL=                        # URL publique bucket (ex: https://pub-xxx.r2.dev) — optionnel
