{
  "name": "tikexo-backend",
  "version": "1.0.0",
  "description": "TIKEXO — Plateforme SaaS titre-restaurant digitalisé pour le Bénin",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "test": "jest",
    "test:unit": "jest --projects=jest.config.js --selectProjects=unit",
    "test:integration": "jest --projects=jest.config.js --selectProjects=integration",
    "test:security": "jest --projects=jest.config.js --selectProjects=security",
    "test:coverage": "jest --coverage",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "node prisma/seed.js",
    "prisma:studio": "prisma studio",
    "lint": "eslint src --ext .js"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.3.1",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "express-validator": "^7.1.0",
    "fedapay": "^1.2.5",
    "firebase-admin": "^12.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "nodemailer": "^6.9.14",
    "qrcode": "^1.5.3",
    "socket.io": "^4.7.5",
    "uuid": "^10.0.0",
    "luxon": "^3.4.4",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "eslint": "^9.5.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "prisma": "^5.14.0",
    "supertest": "^7.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
