{
  "expo": {
    "name": "Tikexo",
    "slug": "tikexo",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "tikexo",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A3C5E"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "bj.tikexo.app",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A3C5E"
      },
      "package": "bj.tikexo.app",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#1A3C5E"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "TIKEXO utilise Face ID pour sécuriser votre compte"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "tikexo-bj"
      }
    }
  }
}
